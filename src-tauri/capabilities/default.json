{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "store:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "https://**" },
        { "url": "http://*" },
        { "url": "http://**" }
      ]
    },
    "opener:allow-open-path",
    "clipboard-manager:allow-write-image",
    "autostart:default"
  ]
}
